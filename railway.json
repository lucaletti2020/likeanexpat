{
  "$schema": "https://railway.app/railway-schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "buildArgs": {
      "VITE_GOOGLE_CLIENT_ID": "${{VITE_GOOGLE_CLIENT_ID}}"
    }
  },
  "deploy": {
    "healthcheckPath": "/",
    "preDeployCommand": "python manage.py migrate --noinput && python manage.py seed"
  }
}
